# ============================================================
# Capital Store MSK — конфиг сервера
# Скопируйте в .env и заполните. Файл .env в git НЕ коммитить.
# Без этих значений сайт работает в демо-режиме.
# ============================================================

# --- VK Market (каталог) ---
# Токен сообщества с доступом к Market:
#   Управление сообществом → Работа с API → Ключи доступа
VK_TOKEN=
# Числовой id сообщества (для capitalstoremsk уже известен)
VK_GROUP_ID=210723656
# Версия VK API (можно не менять)
VK_API_VERSION=5.199

# --- Telegram (заявки) ---
# Токен бота от @BotFather
TG_BOT_TOKEN=
# Куда слать заявки. Несколько получателей — через запятую, без пробелов.
# Пример: TG_CHAT_ID=993987919,123456789
# ID можно узнать у @userinfobot. Получатель должен сам написать боту /start —
# иначе Telegram не разрешит боту ему писать.
TG_CHAT_ID=

# --- Запасной канал доставки заявок ---
# У российских хостеров api.telegram.org заблокирован. Если Telegram недоступен
# напрямую, заявка пересылается на /api/order другого сервера, у которого доступ есть.
# Пример: RELAY_URL=https://capital-store-msk.onrender.com/api/order
RELAY_URL=

# --- Сервер ---
PORT=3000
